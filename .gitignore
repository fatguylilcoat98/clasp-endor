# ----------------------------------------------------------------------------
# Secrets / environment — never commit real values
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets/
credentials*.json
service-account*.json

# ----------------------------------------------------------------------------
# Dependencies
# ----------------------------------------------------------------------------
node_modules/

# ----------------------------------------------------------------------------
# Build artifacts
# ----------------------------------------------------------------------------
build/
dist/
out/
*.tsbuildinfo

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*

# ----------------------------------------------------------------------------
# Local database dumps / data — never commit real data
# ----------------------------------------------------------------------------
*.dump
*.sql.dump
*.sqlite
*.sqlite3
*.bak
*.backup
db/dumps/

# ----------------------------------------------------------------------------
# OS / editor
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ----------------------------------------------------------------------------
# Test / coverage
# ----------------------------------------------------------------------------
coverage/
.nyc_output/
# Manual gauntlet scenarios (GM-30): the directory ships
# (the .gitkeep makes git track it) so the L38 doc-presence
# canary can find it on a fresh CI checkout, but its CONTENT
# is gitignored so local probes never accidentally commit.
tests/gauntlet/manual/*
!tests/gauntlet/manual/.gitkeep

# ----------------------------------------------------------------------------
# Test-door (clasp-endor only) — local-only answers files must not commit
# ----------------------------------------------------------------------------
config/test-door.answers.json
config/test-door.answers.local.json

# ----------------------------------------------------------------------------
# Ad-hoc debug / one-off test scripts at repo root — keep out of the deploy
# bundle. These tend to accumulate connection strings and live API keys.
# ----------------------------------------------------------------------------
debug-*.js
test-db.js
test-*.js
*-debug.js
test_*.js
