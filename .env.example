# ============================================================================
# Lylo Companion — environment template
# ============================================================================
# Copy this file to .env IN A COPIED INSTANCE and fill in real values there.
# Never commit a filled-in .env. Never put real values in this file.
# Placeholder variable names only — values are intentionally blank.
# ============================================================================

# --- AI model ---
ANTHROPIC_API_KEY=

# --- Database (Supabase) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# --- Vector store (Pinecone) ---
PINECONE_API_KEY=
PINECONE_INDEX=

# --- Companion instance configuration ---
LYLO_OWNER_EMAIL=
COMPANION_TIMEZONE=

# --- Feature flags (see docs/governance) ---
LYLO_SHELL_MODE=false

# --- Runtime DB connection (GM-16 / GM-17 — see docs/deployment/operator-runbook.md) ---
# Separate LOGIN roles per process; same database, different effective
# identity. The base lylo_runtime / lylo_setup / lylo_app roles are
# created by db/migrations/007_rls_policies.sql; the LOGIN roles are
# operator-provisioned (CREATE ROLE ... LOGIN PASSWORD '...' IN ROLE
# lylo_*).
#
# Per-role BYPASSRLS posture:
#   lylo_runtime_login: NO  (must remain subject to RLS)
#   lylo_setup_login:   YES (BYPASSRLS does not inherit via IN ROLE)
#   lylo_app_login:     NO  (DO NOT grant — would silently disable
#                            every memory-governance privacy guarantee)
LYLO_RUNTIME_DATABASE_URL=
LYLO_SETUP_DATABASE_URL=
LYLO_APP_DATABASE_URL=
LYLO_PILOT_INSTANCE_ID=

# --- Runtime ---
NODE_ENV=development
PORT=

# --- Test-door web UI (clasp-endor ONLY — never enable in the mold) ---
# These variables are scoped to the disposable test instance. Do not
# back-port them to fatguylilcoat98/AI-companion-GNG. The web entry
# point (`npm run start:web`) refuses to boot unless LYLO_WEB_MODE is
# explicitly true and every DB URL is acceptable per the rule below.
LYLO_WEB_MODE=false
WEB_SESSION_SECRET=
LYLO_TEST_SENIOR_USER_ID=
LYLO_TEST_ADMIN_USER_ID=

# Disposable-test-door escape hatch for Render-hosted Postgres. The
# web boot, the migrate script, and the seed script normally refuse
# any DB URL that is not localhost / 127.0.0.1 / ::1. Setting this
# flag to true RELAXES that rule, but ONLY when LYLO_WEB_MODE=true
# AND LYLO_SHELL_MODE=true are also set on the same process. Any
# single missing flag falls back to local-only. This applies to the
# clasp-endor test door only.
GNG_TEST_INSTANCE_ALLOW_RENDER_DB=false
