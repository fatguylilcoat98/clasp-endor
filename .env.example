# ============================================================================
# clasp-endor — environment template (test instance)
# ============================================================================
# Copy this file to .env and fill in real values there. Never commit a
# filled-in .env. Never put real values in this file.
# Placeholder variable names only — values are intentionally blank.
#
# This is the disposable test instance of fatguylilcoat98/AI-companion-GNG.
# The active deployment runs on Render against Supabase Postgres. Local
# development is secondary.
# ============================================================================

# ----------------------------------------------------------------------------
# Model providers
# ----------------------------------------------------------------------------

# Primary response model — required. Used by src/web/wiring.js to build
# the Anthropic SDK client (single-shot, non-streaming, no tools).
ANTHROPIC_API_KEY=

# Brain pipeline embeddings + sentiment — optional. When absent, brain.js
# degrades gracefully (Priority Filter and Sentiment Analyzer report
# `degraded: true` and fall through to defaults).
OPENAI_API_KEY=

# Memory extractor Layer 2 (LLaMA-3.1-8b-instant) + response auditor —
# optional. When absent, the extractor falls back to Layer 1 patterns
# only and the auditor returns { verdict: 'PASS', details: 'no-groq-key' }.
GROQ_API_KEY=

# ----------------------------------------------------------------------------
# Database — Supabase Postgres (Render-hosted runtime)
# ----------------------------------------------------------------------------
# Required for the memory pool (src/web/wiring.js → createMemoryPool).
# Use the Supabase pooler URI (aws-*.pooler.supabase.com) for Render
# compatibility. SSL is enforced via certs/supabase-ca.crt (bundled).
LYLO_APP_DATABASE_URL=

# Required only by scripts/test-door/seed-test-pilot.js. Same Supabase
# URL is fine for the test door — the role separation (lylo_setup vs
# lylo_runtime vs lylo_app) is a production-only concern.
LYLO_SETUP_DATABASE_URL=

# Used by the legacy boot path (src/runtime/boot.js). Not consumed by
# src/runtime/boot-web.js — set it to the same Supabase URL for
# consistency or leave blank.
LYLO_RUNTIME_DATABASE_URL=

# Override the bundled Supabase CA cert path. Defaults to
# ./certs/supabase-ca.crt. Optional.
DB_CA_CERT_PATH=

# ----------------------------------------------------------------------------
# Test-door identity — UUIDs printed by seed-test-pilot.js
# ----------------------------------------------------------------------------
LYLO_PILOT_INSTANCE_ID=
LYLO_TEST_SENIOR_USER_ID=
LYLO_TEST_ADMIN_USER_ID=

# ----------------------------------------------------------------------------
# Web entry gating — all three flags MUST be true to allow a non-local
# DB URL. Any one missing falls back to the localhost-only rule.
# ----------------------------------------------------------------------------

# Master switch for the legacy boot path. Must be true for the web boot
# path's Render-DB escape hatch to engage.
LYLO_SHELL_MODE=false

# Gates the web entry point. Without this true, src/runtime/boot-web.js
# refuses to start.
LYLO_WEB_MODE=false

# Disposable-test-door escape hatch — allows non-localhost DB URLs only
# when set together with LYLO_WEB_MODE=true and LYLO_SHELL_MODE=true.
# This applies to the clasp-endor test door only; the factory mold's
# boot path does not consult this flag.
GNG_TEST_INSTANCE_ALLOW_RENDER_DB=false

# ----------------------------------------------------------------------------
# Web session — required
# ----------------------------------------------------------------------------
# HMAC-SHA256 secret for the test-door session cookie. Must be a string
# of length >= 16. Rotate by changing the value (invalidates all
# outstanding sessions).
WEB_SESSION_SECRET=

# ----------------------------------------------------------------------------
# Brain pipeline — optional control flags
# ----------------------------------------------------------------------------
# Set to false to bypass the 8-stage brain pipeline and use the
# standard conversation runtime directly. Default: pipeline enabled.
BRAIN_ENABLED=

# Set to true to skip the Groq-based response auditor entirely.
# Default: auditor enabled (fail-open if Groq unavailable).
AUDIT_DISABLED=

# Diagnostic — set to true to log the brain pipeline's per-memory
# ranking (id, authority_level, relevance score, authority boost,
# final score, 80-char content excerpt) on every chat. Use to
# investigate "why is this memory winning" issues, especially when
# a supersession / correction did not produce the expected behavior.
# Default off. Safe to leave on briefly; produces one extra log
# line per chat. Disable when not actively debugging.
LYLO_DEBUG_RETRIEVAL=

# ----------------------------------------------------------------------------
# Supabase Auth — Path 2 identity layer
# ----------------------------------------------------------------------------
# When enabled, signup/login go through Supabase Auth. Each verified
# user gets a distinct public.users row keyed on auth_user_id (added
# in db/migrations/017). The substrate's RLS contract then narrows
# every memory query by that user's distinct UUID — closing the
# cross-user identity leak from the pre-auth test door.
#
# Required when auth is in use (Step 2+ will gate boot-web.js on
# these). Step 1 (this PR) lands the modules; later PRs wire them
# into the endpoint surface.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Comma-separated list of emails that auto-receive role='admin' on
# their FIRST signup. After provisioning, role is in the DB and no
# longer re-checked per request. Promotion of an existing user must
# go through a future admin-promotion flow, not this env var.
# Example:  LYLO_BOOTSTRAP_ADMIN_EMAILS=ops@example.com,founder@example.com
LYLO_BOOTSTRAP_ADMIN_EMAILS=

# Open signup gate for the test door. Set to a comma-separated email
# allowlist (with optional '*@domain.com' patterns) to require pre-
# approval before signup is allowed. Empty/unset = open signup
# (acceptable for a disposable test instance; flip this on the
# moment there's anything real on the deployment).
LYLO_SIGNUP_ALLOWLIST=

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
NODE_ENV=development
# Render's default web service port is 10000. Local dev typically 3000.
PORT=
